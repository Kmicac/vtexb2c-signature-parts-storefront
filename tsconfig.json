{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*", ".faststore/src/*"],
      "@generated": [".faststore/@generated/index.ts"],
      "@generated/*": [".faststore/@generated/*"],
      "@faststore/core": [".faststore/index.ts"],
      "@faststore/core/api": [".faststore/api/index.ts"],
      "@faststore/core/experimental": [".faststore/src/experimental/index.ts"],
      "@faststore/core/experimental/server": [
        ".faststore/src/experimental/server/index.ts"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": ["*.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "public", ".faststore"]
}
