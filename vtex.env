# configures NextJS
NEXT_TELEMETRY_DISABLED=true

# configures WebOps
## Enable re-using node_modules from previous runs for faster builds
USE_BUILD_CACHE=true

## Enable Incremental Static Builds (ISB): 
## https://www.faststore.dev/releases/2022/05/19/webops
USE_STALE_CACHE=true

SITE_HOST=inboundpartnerar.myvtex.com
FASTSTORE_ACCOUNT=inboundpartnerar

VTEX_ACCOUNT=inboundpartnerar
VTEX_WORKSPACE=master
VTEX_ENV=stable
VTEX_REGION=aws-us-east-1

VTEX_PUBLIC_REGION=aws-us-east-1
VTEX_PUBLIC_ACCOUNT=inboundpartnerar
